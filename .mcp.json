{
  "mcpServers": {
    "auth0": {
      "command": "npx",
      "args": ["-y", "@auth0/auth0-mcp-server", "run"],
      "capabilities": ["tools"],
      "env": {
        "DEBUG": "auth0-mcp"
      }
    },
    "demo-server": {
        "type": "http",
        "url": "http://localhost:8000/mcp/"
    }
  }
}